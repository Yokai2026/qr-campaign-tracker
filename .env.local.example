# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Live Mode)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cron
CRON_SECRET=your-cron-secret

# Email (n8n Webhook)
N8N_EMAIL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/spurig-email

# Vercel (Custom Domains API)
# Token: https://vercel.com/account/settings/tokens (Scope: Full Account)
# Project-ID: Vercel Dashboard → Project → Settings → General
# Team-ID: nur bei Team-Account nötig, sonst leer lassen
VERCEL_TOKEN=vcp_...
VERCEL_PROJECT_ID=prj_...
VERCEL_TEAM_ID=
