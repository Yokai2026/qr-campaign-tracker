{
  "name": "Spurig — E-Mail senden",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "spurig-email",
        "authentication": "headerAuth",
        "options": {}
      },
      "id": "webhook-1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "spurig-email"
    },
    {
      "parameters": {
        "fromEmail": "info@spurig.com",
        "toEmail": "={{ $json.body.to }}",
        "subject": "={{ $json.body.subject }}",
        "emailType": "html",
        "html": "={{ $json.body.html }}",
        "options": {
          "senderName": "Spurig"
        }
      },
      "id": "email-1",
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [500, 300],
      "credentials": {
        "smtp": {
          "id": "",
          "name": "Spurig SMTP"
        }
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Send Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
